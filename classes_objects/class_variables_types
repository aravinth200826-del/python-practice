class phone:
    def __init__(self,brand,price,chargertype):     #self,brand,prince,chargertype these are instance variable
        self.brand=brand
        self.price=price
        self.chargertype=chargertype
    def display(self): 
        print("Brand:",self.brand)
        print("Price:",self.price)
        print("Chargertype:",self.chargertype)
        

class a():
    def __init__(self):
        print("A")
class b(a):
    def __init__(self):
        super().__init__()      #this helps to call parent class
        print("B")
c=b()



#example
class Person:
    def show(self):
        print("I am a Person")

class Student(Person):
    def show(self):
        super().show()    # Call parent method
        print("I am a Student")

s = Student()                #I am a Person
                              I am a Student
s.show()

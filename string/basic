def reverse_string(s):
    return s[::-1]

text = "Programming"
print(f"Original: {text}")
print(f"Reversed: {reverse_string(text)}")

# Alternative methods
print(f"Method 2: {''.join(reversed(text))}")
print(f"Method 3: {text[::-1]}")

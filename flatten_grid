#the pythonic and smartest way

def flatten_grid(grid):
    flat_list = []
    
    # Loop directly through each inner list in the main grid
    for inner_list in grid:
        # Loop directly through each number in the inner list
        for number in inner_list:
            flat_list.append(number)
            
    return flat_list

print(flatten_grid([[1, 2, 3], [4, 5], [6, 7, 8, 9]]))
